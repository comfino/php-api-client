{
    "name": "comfino/php-api-client",
    "type": "library",
    "description": "Comfino PHP API client library for the Comfino payment gateway with PSR-7/17/18 support - portable protocol layer for the Comfino REST API.",
    "keywords": [
        "comfino", "payment", "gateway", "api", "client",
        "psr-18", "psr-7", "bnpl", "installments", "pay later"
    ],
    "homepage": "https://github.com/comfino/php-api-client",
    "readme": "README.md",
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Artur Kozubski",
            "email": "akozubski@comperia.pl",
            "homepage": "https://comfino.pl"
        }
    ],
    "support": {
        "issues": "https://github.com/comfino/php-api-client/issues",
        "source": "https://github.com/comfino/php-api-client",
        "docs": "https://github.com/comfino/php-api-client#readme"
    },
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-sodium": "*",
        "ext-zlib": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.10",
        "php-http/mock-client": "^1.6",
        "nyholm/psr7": "^1.8",
        "sunrise/http-client-curl": "^2.2"
    },
    "suggest": {
        "nyholm/psr7": "PSR-7/17 message implementation.",
        "sunrise/http-client-curl": "PSR-18 cURL client implementation."
    },
    "autoload": {
        "psr-4": {
            "Comfino\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Comfino\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-html coverage",
        "cs": "vendor/bin/phpcs",
        "cs-fix": "vendor/bin/phpcbf",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
